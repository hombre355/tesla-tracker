# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# postgresql+asyncpg:// for the app; host "db" resolves via Docker Compose
# For local dev without containers: postgresql+asyncpg://tesla:tesla@localhost:5432/tesla_tracker
DATABASE_URL=postgresql+asyncpg://tesla:tesla@db:5432/tesla_tracker

# Frontend URL for post-auth redirect (use http://localhost for containers)
FRONTEND_URL=http://localhost:5173
